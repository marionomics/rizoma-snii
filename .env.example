# Copia este archivo como .env y llena tus datos.
# .env está en .gitignore — nunca lo subas al repositorio.

# ── Credenciales Rizoma (obligatorio) ──────────────────────────────────────
RIZOMA_USER=tu_correo@ejemplo.com
RIZOMA_PASSWORD=tu_contraseña

# ── Institución de adscripción ─────────────────────────────────────────────
# ID numérico de la institución en el catálogo de Rizoma.
# Para encontrar tu INSTITUCION_ID: en la plataforma, al guardar cualquier
# registro, abre DevTools → Network → busca la petición POST → en el JSON
# del campo "institucion" encontrarás el "id" numérico.
INSTITUCION_ID=12345
INSTITUCION_CLAVE=1234567
INSTITUCION_NOMBRE=NOMBRE COMPLETO DE TU INSTITUCION EN MAYUSCULAS
INSTITUCION_ESTADO_CLAVE=XXX
INSTITUCION_ESTADO_NOMBRE=NombreDelEstado
# nivelUno: 01=Pública  02=Privada
INSTITUCION_NIVEL_UNO_ID=01
INSTITUCION_NIVEL_UNO_NOMBRE=Pública
# nivelDos: 01=Federal  02=Estatal  03=Autónoma  04=Particular
INSTITUCION_NIVEL_DOS_ID=02
INSTITUCION_NIVEL_DOS_NOMBRE=Estatal

# ── Blog de divulgación (opcional, solo para medios-escritos) ───────────────
# Dominio de tu blog sin https:// ni slash final
BLOG_DOMAIN=tublog.com
